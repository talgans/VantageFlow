rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /profile_photos/{userId}/{allPaths=**} {
      // Allow read access to everyone (so profile photos can be displayed)
      allow read: if true;
      // Allow write access if the user is authenticated and it's their own folder, or if they are an admin
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.role == 'admin');
    }
    match /task_images/{allPaths=**} {
      // Allow read access to all authenticated users
      allow read: if request.auth != null;
      // Allow write access to all authenticated users
      allow write: if request.auth != null;
    }
  }
}
